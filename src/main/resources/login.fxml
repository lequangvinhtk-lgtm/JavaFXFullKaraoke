<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.vku.karaoke.client.controller.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="14" styleClass="login-card">

        <Label text="🎤" styleClass="login-logo"/>

        <Label fx:id="lblTitle"
               text="KARAOKE MANAGER"
               styleClass="login-title"/>

        <Label fx:id="lblSubtitle"
               text="Đăng nhập để quản lý bài hát, playlist và lịch sử tìm kiếm"
               styleClass="login-subtitle"
               wrapText="true"
               maxWidth="360"/>

        <Region prefHeight="8"/>

        <TextField fx:id="txtUsername"
                   promptText="Tên đăng nhập"
                   maxWidth="340"
                   styleClass="login-input"/>

        <PasswordField fx:id="txtPassword"
                       promptText="Mật khẩu"
                       maxWidth="340"
                       styleClass="login-input"/>

        <PasswordField fx:id="txtConfirmPassword"
                       promptText="Nhập lại mật khẩu"
                       maxWidth="340"
                       visible="false"
                       managed="false"
                       styleClass="login-input"/>

        <Button fx:id="btnSubmit"
                text="Đăng nhập"
                onAction="#handleSubmit"
                maxWidth="340"
                styleClass="login-primary-button"/>

        <Button fx:id="btnSwitchMode"
                text="Chưa có tài khoản? Đăng ký"
                onAction="#handleSwitchMode"
                maxWidth="340"
                styleClass="login-link-button"/>

        <Label fx:id="lblMessage"
               wrapText="true"
               maxWidth="340"
               styleClass="login-message"/>

    </VBox>
</StackPane>